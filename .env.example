# Public site URL (used by SEO helpers)
NEXT_PUBLIC_SITE_URL=https://devsnio.com

# ── Contact form mailer (Zoho Mail SMTP) ──
#
# Setup (one time):
#   1. Sign into Zoho Mail with info@devsnio.com
#   2. Go to Settings → Security → App Passwords
#      (or https://accounts.zoho.com/home#security/app_passwords)
#   3. Generate an app password for "Mail / SMTP"
#   4. Paste the password below as SMTP_PASS
#
# Notes:
#   - Region: smtp.zoho.com (US), smtp.zoho.eu (EU), smtp.zoho.in (India)
#   - If you're on Zoho Mail Workplace / paid plan with a custom domain,
#     use smtppro.zoho.com instead
#   - SMTP/IMAP access must be enabled in Zoho Settings → Mail Accounts
#
SMTP_HOST=smtp.zoho.com
SMTP_PORT=465
SMTP_SECURE=true
SMTP_USER=info@devsnio.com
SMTP_PASS=your-zoho-app-password

# Who the form's email shows as from/to
MAIL_FROM="devsnio <info@devsnio.com>"
MAIL_TO=info@devsnio.com
